{% extends "_layout.twig" %}
{% block inhalt %}
<article class="werk">

  <header class="werk__kopf">
    <p class="werk__nummer">{{ entry.inventarnummer }} | {{ entry.jahr }}</p>
    <h1 class="werk__titel">{{ entry.title }}</h1>
    {% if entry.unterueberschrift %}
      <p class="werk__untertitel">{{ entry.unterueberschrift }}</p>
    {% endif %}
  </header>

  {% if entry.werkbeschreibung %}
    <div class="werk__beschreibung">{{ entry.werkbeschreibung|nl2br }}</div>
  {% endif %}

<div class="werk__medien {% if entry.bilder.count() > 1 %}werk__medien--mehrbild{% endif %}">
  {% set kriterien = { section: 'werke', orderBy: 'inventarnummer ASC' } %}
  {% set vorheriges = entry.getPrev(kriterien) %}
  {% set naechstes = entry.getNext(kriterien) %}

  {% if vorheriges %}
    <a class="werk__blaettern werk__blaettern--zurueck" href="{{ vorheriges.url }}" aria-label="Vorheriges Werk">‹</a>
  {% endif %}
  {% if naechstes %}
    <a class="werk__blaettern werk__blaettern--weiter" href="{{ naechstes.url }}" aria-label="Nächstes Werk">›</a>
  {% endif %}
  <div class="werk__bilder">
    {% for bild in entry.bilder.all() %}
      <img src="{{ bild.url }}" alt="{{ bild.title }}">
    {% endfor %}
  </div>

<button type="button" class="werk__pin" aria-label="Daten anheften">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M15.113 3.21l.094 .083l5.5 5.5a1 1 0 0 1 -1.175 1.59l-3.172 3.171l-1.424 3.797a1 1 0 0 1 -.158 .277l-.07 .08l-1.5 1.5a1 1 0 0 1 -1.32 .082l-.095 -.083l-2.793 -2.792l-3.793 3.792a1 1 0 0 1 -1.497 -1.32l.083 -.094l3.792 -3.793l-2.792 -2.793a1 1 0 0 1 -.083 -1.32l.083 -.094l1.5 -1.5a1 1 0 0 1 .258 -.187l.098 -.042l3.796 -1.425l3.171 -3.17a1 1 0 0 1 1.497 -1.26z" />
    </svg>
  </button>
 
  
  <dl class="werk__daten">
    {% if entry.kategorie.value %}<div class="daten__feld"><dt>Kategorie</dt><dd>{{ entry.kategorie.label }}</dd></div>{% endif %}
    {% if entry.technik %}<div class="daten__feld"><dt>Technik</dt><dd>{{ entry.technik }}</dd></div>{% endif %}
    {% if entry.chrominanz %}<div class="daten__feld"><dt>Chrominanz</dt><dd>{{ entry.chrominanz }}</dd></div>{% endif %}
    {% if entry.material %}<div class="daten__feld"><dt>Material</dt><dd>{{ entry.material|nl2br }}</dd></div>{% endif %}
    {% if entry.dauer %}<div class="daten__feld"><dt>Dauer</dt><dd>{{ entry.dauer }}</dd></div>{% endif %}
    {% if entry.audio %}<div class="daten__feld"><dt>Audio</dt><dd>{{ entry.audio }}</dd></div>{% endif %}
    {% if entry.erhaltungszustand %}<div class="daten__feld"><dt>Erhaltungszustand</dt><dd>{{ entry.erhaltungszustand }}</dd></div>{% endif %}
    {% if entry.auszeichnung %}<div class="daten__feld"><dt>Auszeichnung</dt><dd>{{ entry.auszeichnung }}</dd></div>{% endif %}
    {% if entry.besitz %}<div class="daten__feld"><dt>Besitz</dt><dd>{{ entry.besitz }}</dd></div>{% endif %}
    {% if entry.standort %}<div class="daten__feld"><dt>Standort</dt><dd>{{ entry.standort }}</dd></div>{% endif %}
    {% if entry.rechteverwertung %}<div class="daten__feld"><dt>Rechteverwertung</dt><dd>{{ entry.rechteverwertung }}</dd></div>{% endif %}
    {% if entry.rechtenachweise %}<div class="daten__feld"><dt>Rechtenachweise</dt><dd>{{ entry.rechtenachweise }}</dd></div>{% endif %}
    {% if entry.dokumente %}<div class="daten__feld"><dt>Dokumente</dt><dd>{% for zeile in entry.dokumente|split('\n') %}{{ zeile|trim }}{% if not loop.last %}<br>{% endif %}{% endfor %}</dd></div>{% endif %}
    {% if entry.urband %}<div class="daten__feld"><dt>Urband</dt><dd>{{ entry.urband }}</dd></div>{% endif %}
    {% if entry.foerderung %}<div class="daten__feld"><dt>Förderung</dt><dd>{{ entry.foerderung }}</dd></div>{% endif %}
    {% if entry.speichermedium %}<div class="daten__feld"><dt>Speichermedium</dt><dd>{{ entry.speichermedium }}</dd></div>{% endif %}
    {% if entry.mitwirkende %}<div class="daten__feld"><dt>Mitwirkende</dt><dd>{{ entry.mitwirkende|nl2br }}</dd></div>{% endif %}
    {% if entry.wettbewerb %}<div class="daten__feld"><dt>Wettbewerb</dt><dd>{{ entry.wettbewerb }}</dd></div>{% endif %}
  </dl>
</div>

</article>
{% endblock %}